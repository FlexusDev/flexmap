{
  "name": "flexmap",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean": "rm -rf dist releases",
    "clean:all": "npm run clean && rm -rf src-tauri/target",
    "build:portable:win": "npm run build && tauri build --no-bundle",
    "build:portable:mac": "npm run build && tauri build --bundles app",
    "build:win:mac": "npm run build && tauri build --no-bundle --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "build:win:mac:nsis": "npm run build && tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc --bundles nsis",
    "release:mac": "npm run build:portable:mac && ./scripts/release-mac.sh",
    "build:both": "npm run build && tauri build --bundles app && tauri build --no-bundle --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "gl-matrix": "^3.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.6.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@tailwindcss/vite": "^4.1.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
